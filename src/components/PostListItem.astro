---
import type { CollectionEntry } from 'astro:content'

type Props = {
  post: CollectionEntry<'posts'>
}

const { post } = Astro.props

const formattedDate = post.data.publishDate.toLocaleDateString('en-PH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const isoDate = post.data.publishDate.toISOString()
---

<article
  class="group relative border-b border-apple-border py-8 last:border-b-0 dark:border-apple-border-dark"
>
  <time
    class="text-sm text-apple-text-secondary"
    datetime={isoDate}
  >
    {formattedDate}
  </time>
  <h3 class="mt-2 text-xl font-semibold tracking-tight-apple">
    <a
      href={`/posts/${post.id}`}
      class="transition-colors group-hover:text-apple-accent dark:group-hover:text-apple-accent-dark after:absolute after:inset-0"
    >
      {post.data.title}
    </a>
  </h3>
  <p class="mt-2 leading-relaxed text-apple-text-secondary">
    {post.data.description}
  </p>
</article>
