---
const { pathname } = Astro.url

const links = [
  { href: '/', label: 'Home' },
  { href: '/projects', label: 'Projects' },
  { href: '/posts', label: 'Posts' },
]
---

<nav
  class="fixed top-0 right-0 left-0 z-50 h-12 border-b border-apple-border/50 bg-apple-surface/80 backdrop-blur-xl backdrop-saturate-150 dark:border-apple-border-dark/50 dark:bg-apple-surface-dark/80"
  transition:persist
>
  <div class="mx-auto flex h-full max-w-5xl items-center justify-between px-6">
    <a href="/" aria-label="Home">
      <img
        src="/apple-touch-icon.png"
        alt="CJ"
        class="size-7 rounded-full"
        width="28"
        height="28"
      />
    </a>
    <ul class="flex items-center gap-6">
      {links.map(({ href, label }) => {
        const isActive = href === '/'
          ? pathname === '/'
          : pathname.startsWith(href)
        return (
          <li>
            <a
              href={href}
              class:list={[
                'text-xs font-medium transition-colors',
                isActive
                  ? 'text-apple-text dark:text-apple-text-dark'
                  : 'text-apple-text-secondary hover:text-apple-text dark:hover:text-apple-text-dark',
              ]}
            >
              {label}
            </a>
          </li>
        )
      })}
    </ul>
  </div>
</nav>
