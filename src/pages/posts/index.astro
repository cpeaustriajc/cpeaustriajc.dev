---
import { Image } from 'astro:assets'
import { getCollection, getEntry } from 'astro:content'
import PostListItem from '~/components/PostListItem.astro'
import BaseLayout from '~/layouts/BaseLayout.astro'

const posts = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true
}).then((posts) =>
  posts.sort((a, b) => Number(b.data.publishDate) - Number(a.data.publishDate)),
)
const meta = await getEntry('meta', 'posts')

const [featured, ...remainingPosts] = posts

const postsByYear = Map.groupBy(remainingPosts, (post) =>
  post.data.publishDate.getFullYear(),
)
const sortedYears = [...postsByYear.keys()].sort((a, b) => b - a)

const featuredAuthor = await getEntry(featured.data.author)
const featuredDate = featured.data.publishDate.toLocaleDateString('en-PH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})
---

<BaseLayout {meta}>
  <div class="mx-auto max-w-3xl px-6 pt-16 pb-24">
    <h1
      class="text-4xl font-semibold tracking-tighter-apple sm:text-5xl"
    >
      Posts
    </h1>
    <p class="mt-3 text-lg text-apple-text-secondary">
      Articles and tutorials on engineering and technology.
    </p>

    <article class="group relative mt-12">
      <div class="overflow-hidden rounded-2xl">
        <Image
          src={featured.data.coverImage}
          alt={featured.data.coverImageAlt}
          widths={[400, 720, 960]}
          sizes="(max-width: 768px) 100vw, 720px"
          class="aspect-3/2 w-full object-cover transition-transform duration-500 group-hover:scale-[1.02] sm:aspect-2/1"
        />
      </div>
      {featured.data.keywords.length > 0 && (
        <div class="mt-4 flex flex-wrap gap-2">
          {featured.data.keywords.map((keyword) => (
            <span class="rounded-full border border-apple-border px-2.5 py-0.5 text-xs text-apple-text-secondary dark:border-apple-border-dark">
              {keyword}
            </span>
          ))}
        </div>
      )}
      <h2 class="mt-4 text-2xl font-semibold tracking-tight-apple sm:text-3xl">
        <a
          href={`/posts/${featured.id}`}
          class="transition-colors group-hover:text-apple-accent dark:group-hover:text-apple-accent-dark after:absolute after:inset-0"
        >
          {featured.data.title}
        </a>
      </h2>
      <p class="mt-3 text-lg leading-relaxed text-apple-text-secondary">
        {featured.data.description}
      </p>
      <p class="mt-3 text-sm text-apple-text-secondary">
        <time datetime={featured.data.publishDate.toISOString()}>
          {featuredDate}
        </time>
        <span class="mx-2">&middot;</span>
        {featuredAuthor?.data.name}
      </p>
    </article>

    {sortedYears.map((year) => (
      <section class="mt-16">
        <h2 class="border-b border-apple-border pb-4 text-sm font-semibold uppercase tracking-widest text-apple-text-secondary dark:border-apple-border-dark">
          {year}
        </h2>
        {postsByYear.get(year)!.map((post) => (
          <PostListItem post={post} />
        ))}
      </section>
    ))}
  </div>
</BaseLayout>
