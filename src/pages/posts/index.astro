---
import BaseLayout from '~/layouts/BaseLayout.astro'
import { getCollection, getEntry } from 'astro:content'
import Post from '~/components/Post.astro'

const posts = await getCollection('posts', ({ data }) => {
  return import.meta.env.PROD ? data.draft !== true : true
}).then((posts) =>
  posts.sort(
    (a, b) => Number(b.data.publishDate) - Number(a.data.publishDate),
  ),
)
const meta = await getEntry('meta', 'posts')
---

<BaseLayout {meta}>
  <div class="mx-auto max-w-5xl px-6 pt-16 pb-24">
    <h1
      class="text-4xl font-semibold tracking-tighter-apple sm:text-5xl"
    >
      Posts
    </h1>
    <p class="mt-3 text-lg text-apple-text-secondary">
      Articles and tutorials on engineering and technology.
    </p>
    <div
      class="mt-12 grid grid-cols-1 gap-6 sm:grid-cols-2 lg:grid-cols-3"
    >
      {posts.map((post) => <Post post={post} />)}
    </div>
  </div>
</BaseLayout>
