---
import { render } from 'astro:content'
import { getCollection, getEntry, type CollectionEntry } from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'

type Props = {
  entry: CollectionEntry<'posts'>
}

export async function getStaticPaths() {
  const postEntries = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  })

  return postEntries.map((postEntry) => ({
    params: { slug: postEntry.id },
    props: { entry: postEntry },
  }))
}

const { entry } = Astro.props

const date = entry.data.publishDate.toLocaleDateString('en-PH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const { Content } = await render(entry)

const author = await getEntry('authors', entry.data.author.id)
const meta = {
  data: {
    title: entry.data.title,
    description: entry.data.description,
    image: entry.data.coverImage,
    imageAlt: entry.data.coverImageAlt,
    keywords: entry.data.keywords,
  },
}
---

<BaseLayout {meta}>
  <article class="mx-auto max-w-2xl px-6 pt-16 pb-24" transition:animate="slide">
    <nav class="mb-8">
      <a
        href="/posts"
        class="text-sm font-medium text-apple-accent transition-colors hover:text-apple-accent-hover dark:text-apple-accent-dark dark:hover:text-apple-accent-hover-dark"
      >
        &larr; All Posts
      </a>
    </nav>

    <header>
      <h1
        class="text-4xl font-semibold tracking-tighter-apple sm:text-5xl"
      >
        {entry.data.title}
      </h1>
      <p class="mt-4 text-sm text-apple-text-secondary">
        <time datetime={entry.data.publishDate.toISOString()}>
          {date}
        </time>
        <span class="mx-2">&middot;</span>
        <a
          href={author?.data.url}
          class="text-apple-accent hover:text-apple-accent-hover dark:text-apple-accent-dark dark:hover:text-apple-accent-hover-dark"
          target="_blank"
          rel="noopener noreferrer"
        >
          {author?.data.name}
        </a>
      </p>
    </header>

    <div
      class="prose dark:prose-invert lg:prose-lg mt-12 max-w-none prose-headings:tracking-tight prose-a:text-apple-accent prose-a:no-underline hover:prose-a:underline dark:prose-a:text-apple-accent-dark"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
