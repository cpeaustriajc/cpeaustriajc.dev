---
import { Image } from 'astro:assets'
import {
  type CollectionEntry,
  getCollection,
  getEntry,
  render,
} from 'astro:content'
import BaseLayout from '~/layouts/BaseLayout.astro'

type Props = {
  entry: CollectionEntry<'posts'>
}

export async function getStaticPaths() {
  const postEntries = await getCollection('posts', ({ data }) => {
    return import.meta.env.PROD ? data.draft !== true : true
  })

  return postEntries.map((postEntry) => ({
    params: { slug: postEntry.id },
    props: { entry: postEntry },
  }))
}

const { entry } = Astro.props

const date = entry.data.publishDate.toLocaleDateString('en-PH', {
  year: 'numeric',
  month: 'long',
  day: 'numeric',
})

const { Content } = await render(entry)

const author = await getEntry('authors', entry.data.author.id)
const meta = {
  data: {
    title: entry.data.title,
    description: entry.data.description,
    image: entry.data.coverImage,
    imageAlt: entry.data.coverImageAlt,
    keywords: entry.data.keywords,
  },
}
---

<BaseLayout {meta}>
  <article transition:animate="slide">
    <nav class="mx-auto max-w-3xl px-6 pt-16">
      <a
        href="/posts"
        class="text-sm font-medium text-apple-accent transition-colors hover:text-apple-accent-hover dark:text-apple-accent-dark dark:hover:text-apple-accent-hover-dark"
      >
        &larr; All Posts
      </a>
    </nav>

    <header class="mx-auto mt-10 max-w-3xl px-6">
      <div class="flex items-center gap-3 text-sm text-apple-text-secondary">
        <time datetime={entry.data.publishDate.toISOString()}>
          {date}
        </time>
        {entry.data.keywords.length > 0 && (
          <>
            <span>&middot;</span>
            <div class="flex flex-wrap gap-2">
              {entry.data.keywords.slice(0, 3).map((keyword) => (
                <span class="rounded-full border border-apple-border px-2.5 py-0.5 text-xs dark:border-apple-border-dark">
                  {keyword}
                </span>
              ))}
            </div>
          </>
        )}
      </div>
      <h1
        class="mt-4 text-4xl font-semibold tracking-tighter-apple text-balance sm:text-5xl"
      >
        {entry.data.title}
      </h1>
      <p class="mt-4 text-lg leading-relaxed text-apple-text-secondary">
        {entry.data.description}
      </p>
      <p class="mt-4 text-sm text-apple-text-secondary">
        By{' '}
        <a
          href={author?.data.url}
          class="text-apple-accent hover:text-apple-accent-hover dark:text-apple-accent-dark dark:hover:text-apple-accent-hover-dark"
          target="_blank"
          rel="noopener noreferrer"
        >
          {author?.data.name}
        </a>
      </p>
    </header>

    <figure class="mx-auto mt-10 max-w-4xl px-6">
      <Image
        src={entry.data.coverImage}
        alt={entry.data.coverImageAlt}
        widths={[480, 768, 1024]}
        sizes="(max-width: 768px) 100vw, 896px"
        class="w-full rounded-2xl object-cover"
      />
      <figcaption class="mt-3 text-center text-sm text-apple-text-secondary">
        {entry.data.coverImageAlt}
      </figcaption>
    </figure>

    <div
      class="prose dark:prose-invert lg:prose-lg mx-auto mt-12 max-w-3xl px-6 pb-24 prose-headings:tracking-tight prose-a:text-apple-accent prose-a:no-underline hover:prose-a:underline dark:prose-a:text-apple-accent-dark"
    >
      <Content />
    </div>
  </article>
</BaseLayout>
