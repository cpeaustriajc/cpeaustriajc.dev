---
import BaseLayout from '~/layouts/BaseLayout.astro'
---

<BaseLayout>
  <div class="flex min-h-[calc(100dvh-3rem)] items-center justify-center px-6">
    <div class="text-center">
      <p class="text-sm font-semibold text-apple-accent dark:text-apple-accent-dark">
        500
      </p>
      <h1
        class="mt-2 text-4xl font-semibold tracking-tighter-apple sm:text-5xl"
      >
        Something went wrong
      </h1>
      <p class="mt-4 text-apple-text-secondary">
        An unexpected error occurred. Please try again later.
      </p>
      <a
        href="/"
        class="mt-6 inline-block text-sm font-medium text-apple-accent transition-colors hover:text-apple-accent-hover dark:text-apple-accent-dark dark:hover:text-apple-accent-hover-dark"
      >
        &larr; Go home
      </a>
    </div>
  </div>
</BaseLayout>
